class Solution {
    public int reverse(int x) {
        int sign = x > 0 ? 1 : -1;
        int temp = Math.abs(x);
        int rev = 0;
        int num  = 0;
        
        while(temp != 0){
            rev = temp%10;
            //Check the overflow before multiplying
            if(num > (Integer.MAX_VALUE - rev)/10){
                return 0;
            }
            num = num*10 + rev ;
            temp = temp/10;
        }
        num = num * sign ;
        return num; 
    }
}
